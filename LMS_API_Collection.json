    {
      "name": "2. Courses",
      "item": [
        {
          "name": "Get All Courses",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/courses",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "courses"
              ]
            },
            "description": "Fetch all course catalog specifications available in the system."
          },
          "response": []
        },
        {
          "name": "Get Courses by Category",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/courses?category=Computer Science",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "courses"
              ],
              "query": [
                {
                  "key": "category",
                  "value": "Computer Science"
                }
              ]
            },
            "description": "Filters the Course directory to only show courses in a particular Category (e.g. 'Computer Science')."
          },
          "response": []
        },
        {
          "name": "Create Course (Teacher Only)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.success && jsonData.course) {",
                  "    pm.collectionVariables.set(\"course_id\", jsonData.course._id);",
                  "    pm.test(\"Course Created Successfully\", function () {",
                  "        pm.response.to.have.status(201);",
                  "    });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Introduction to Mongoose ODM\",\n  \"description\": \"Learn schemas, compound modeling, reference validations, and query populate operations in MongoDB using Mongoose.\",\n  \"category\": \"Computer Science\",\n  \"duration\": \"6 Weeks\",\n  \"syllabus\": [\n    \"Setup & Database Connects\",\n    \"Defining Schemas & Pre-save Hooks\",\n    \"CRUD operations and Document population\",\n    \"Compound validations and unique indexes\"\n  ]\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/api/courses",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "courses"
              ]
            },
            "description": "Create a new course. (NOTE: Must login as Teacher first so that the collection token belongs to a teacher account). The newly created course ID is automatically saved as a collection variable."
          },
          "response": []
        },
        {
          "name": "Get Single Course",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/courses/{{course_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "courses",
                "{{course_id}}"
              ]
            },
            "description": "Fetch detailed description and instructor populated credentials of a course using its unique ID."
          },
          "response": []
        },
        {
          "name": "Update Course Specification (Teacher Owner)",
          "request": {
            "method": "PUT",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Advanced Mongoose ODM Design\",\n  \"description\": \"Mastering compound database indices, transaction processing, Mongoose aggregations, and performance profiling in Express.\",\n  \"category\": \"Computer Science\",\n  \"duration\": \"8 Weeks\",\n  \"syllabus\": [\n    \"Aggregation pipelines & filters\",\n    \"Database Transactions\",\n    \"Performance Profiling & Mongoose Middleware Hooks\"\n  ]\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/api/courses/{{course_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "courses",
                "{{course_id}}"
              ]
            },
            "description": "Modify the details of a course. This will succeed ONLY if the currently logged-in Teacher is the actual creator/instructor of this course."
          },
          "response": []
        },
        {
          "name": "Delete Course (Teacher Owner)",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/courses/{{course_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "courses",
                "{{course_id}}"
              ]
            },
            "description": "Deletes a course and all associated student enrollments in a single batch. Succeeds only if logged-in user is the course instructor."
          },
          "response": []
        }
      ],
      "description": "Courses catalog directories and CRUD endpoints. Gated by authentication and teacher verification rules."
    },
    {
      "name": "3. Enrollments",
      "item": [
        {
          "name": "Enroll in Course (Student Only)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.success && jsonData.enrollment) {",
                  "    pm.collectionVariables.set(\"enrollment_id\", jsonData.enrollment._id);",
                  "    pm.test(\"Enrolled in Course Successfully\", function () {",
                  "        pm.response.to.have.status(201);",
                  "    });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"courseId\": \"{{course_id}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/api/enrollments",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "enrollments"
              ]
            },
            "description": "Registers the active student in the course specified by `course_id`. (NOTE: Must login as Student first!). Saves the generated enrollment record ID automatically."
          },
          "response": []
        },
        {
          "name": "Get Enrollments List",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/enrollments",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "enrollments"
              ]
            },
            "description": "Fetch active enrollment data. Scoped automatically:\n- Logged-in Student gets their registered courses checklist and progress.\n- Logged-in Teacher gets students rosters who registered for the courses they teach."
          },
          "response": []
        },
        {
          "name": "Update Progress (0-100%)",
          "request": {
            "method": "PUT",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"progress\": 45\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/api/enrollments/{{enrollment_id}}/progress",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "enrollments",
                "{{enrollment_id}}",
                "progress"
              ]
            },
            "description": "Updates progress percentage for a student's active enrollment. (Valid values: 0 to 100). Sets status to 'completed' automatically when progress reaches 100."
          },
          "response": []
        },
        {
          "name": "Complete Course Progress (100%)",
          "request": {
            "method": "PUT",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"progress\": 100\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/api/enrollments/{{enrollment_id}}/progress",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "enrollments",
                "{{enrollment_id}}",
                "progress"
              ]
            },
            "description": "Complete the course progress to 100%. This updates the course status automatically to 'completed'."
          },
          "response": []
        },
        {
          "name": "Unenroll / Cancel Enrollment",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/enrollments/{{enrollment_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "enrollments",
                "{{enrollment_id}}"
              ]
            },
            "description": "Cancels enrollment and deletes the enrollment record. Students can unenroll themselves, and Teachers can purge registrations from courses they teach."
          },
          "response": []
        }
      ],
      "description": "Course enrollment operations, progress tracking, and unenrollments catalog."
    }
